{
  "extends": "./.wxt/tsconfig.json",
  "include": [
    "**/*.ts",
    "./typed-router.d.ts",
    "./.wxt/wxt.d.ts"
  ],
  "compilerOptions": {
    "types": [
      "vue-vine/macros"
    ]
  },
  "vueCompilerOptions": {
    "plugins": [
      "vue-router/volar/sfc-route-blocks",
      "vue-router/volar/sfc-typed-router"
    ]
  }
}